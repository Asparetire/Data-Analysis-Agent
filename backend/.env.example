# LLM provider: "openai" (default) or "anthropic". Change + restart backend.
LLM_PROVIDER=openai

# OpenAI-compatible (Ark v3 endpoint, OpenAI itself, etc.)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic-compatible (Claude, Ark /api/coding endpoint, etc.)
# Used only when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=your-anthropic-or-ark-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# Official Anthropic API: leave unset. Ark coding endpoint:
# ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding

# 主库
DATABASE_URL=sqlite:///./data/main.db

# 数据目录（uploads/ 和 sqlite/ 都会建在这里）
DATA_DIR=./data

# Redis（如果不用可忽略）
REDIS_URL=redis://localhost:6379/0

# CORS，JSON 数组或逗号分隔
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Phase 4A: 认证 / JWT — 生产环境必须覆盖 JWT_SECRET
JWT_SECRET=please-override-in-prod-with-a-long-random-string
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Phase 4A: 首次启动时把已有的无主数据源 / 会话回填到这个默认 admin。
# 仅迁移路径会用到；后续用户应自行注册。
# 启动时校验：必须 ≥ 12 字节且不是占位值，否则 fatal 退出。
# 还须含字母 + 数字（register() 的复杂度策略）。
MIGRATION_ADMIN_EMAIL=admin@local.dev
MIGRATION_ADMIN_PASSWORD=please-change-me-12+chars

# Phase 4B: 限流（per-user / per-IP, 每分钟）
RATE_LIMIT_PER_USER_PER_MINUTE=60
RATE_LIMIT_PER_IP_PER_MINUTE=20

# Phase 6: per-user 并发 SSE 长连接上限
MAX_CONCURRENT_SSE_PER_USER=5

# Phase 6: 信任的反代 IP / CIDR（逗号分隔）。仅当对端 IP 命中此列表时
# 才认 X-Forwarded-For，防止直连场景 XFF 伪造绕过 per-IP 限流。
# 生产部署在 nginx/LB 后面时设为反代容器的 IP/CIDR。
TRUSTED_PROXIES=127.0.0.1,::1

# Phase 6: LLM 单次调用超时（秒）
LLM_REQUEST_TIMEOUT_S=60.0

# Phase 5B: 日志格式 json|text。生产用 json 方便 ELK/Loki 摄入，本地 text 可读
LOG_FORMAT=json

# Phase 5C: MinIO 备份目标（docker-compose 起 minio 服务，S3 兼容）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=please-change-min-8-chars
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET=data-analysis-backups
BACKUP_RETENTION_DAYS=7
# Redis dump.rdb 绝对路径。backup.py 默认用 CONFIG GET 探测；
# 若 Redis 禁用 CONFIG 命令（生产加固），在此显式指定。
# REDIS_DUMP_PATH=/data/dump.rdb

# Phase 4E: mock LLM 模式。E2E 测试和本地无 OpenAI key 时用，返回固定回复。
# 生产环境绝不开启。
# LLM_MOCK=1
