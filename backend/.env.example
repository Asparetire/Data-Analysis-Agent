# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# 主库
DATABASE_URL=sqlite:///./data/main.db

# 数据目录（uploads/ 和 sqlite/ 都会建在这里）
DATA_DIR=./data

# Redis（如果不用可忽略）
REDIS_URL=redis://localhost:6379/0

# CORS，JSON 数组或逗号分隔
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Phase 4A: 认证 / JWT — 生产环境必须覆盖 JWT_SECRET
JWT_SECRET=please-override-in-prod-with-a-long-random-string
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Phase 4A: 首次启动时把已有的无主数据源 / 会话回填到这个默认 admin。
# 仅迁移路径会用到；后续用户应自行注册。
MIGRATION_ADMIN_EMAIL=admin@local.invalid
MIGRATION_ADMIN_PASSWORD=change-me-now

# Phase 4B: 限流（per-user / per-IP, 每分钟）
RATE_LIMIT_PER_USER_PER_MINUTE=60
RATE_LIMIT_PER_IP_PER_MINUTE=20
