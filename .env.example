# docker-compose env interpolation. Copy to .env (gitignored) and fill in.
# The backend runtime reads its own config from backend/.env via pydantic
# — this file is ONLY for the ${VAR} substitutions in docker-compose.yml.

# --- Phase 4A: auth (compose blocks startup without these) ---
# JWT_SECRET must be ≥32 bytes and not the placeholder.
# MIGRATION_ADMIN_PASSWORD must be ≥12 bytes and not the placeholder.
# Backend will refuse to boot otherwise.
JWT_SECRET=please-override-with-a-long-random-string-32-bytes-min
MIGRATION_ADMIN_PASSWORD=please-override-with-a-strong-random-password

# --- Phase 5C: MinIO backup target ---
MINIO_ROOT_PASSWORD=please-change-min-8-chars

# --- LLM provider (optional — backend has its own .env fallback) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_BASE_URL=

# --- Phase 4A: token TTL (optional, has defaults) ---
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
MIGRATION_ADMIN_EMAIL=admin@local.invalid

# --- Phase 4B: rate limits (optional, has defaults) ---
RATE_LIMIT_PER_USER_PER_MINUTE=60
RATE_LIMIT_PER_IP_PER_MINUTE=20

# --- Phase 6: per-user concurrent SSE cap (optional, default 5) ---
MAX_CONCURRENT_SSE_PER_USER=5

# --- Phase 6: trusted proxies for X-Forwarded-For (comma-separated) ---
# Set to the nginx/LB container's IP/CIDR in production.
TRUSTED_PROXIES=127.0.0.1,::1

# --- Phase 6: LLM call timeout in seconds (optional, default 60) ---
LLM_REQUEST_TIMEOUT_S=60.0

# --- Phase 6: CIDR allowed to scrape /metrics (default loopback) ---
# Set to the Prometheus scraper's CIDR in production.
METRICS_ALLOW_CIDR=127.0.0.1/32

# --- Phase 5B: log format json|text (optional, default json) ---
LOG_FORMAT=json

# --- CORS (optional, default allows localhost) ---
CORS_ORIGINS=["http://localhost"]
